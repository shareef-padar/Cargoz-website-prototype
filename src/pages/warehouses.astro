---
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>321 Warehouses in Dubai — Cargoz</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link rel="stylesheet" href="/styles/tokens.css" />
  <link rel="stylesheet" href="/styles/utilities.css" />
  <style is:global>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --primary-500: #7957FF;
      --secondary-500: #40BCAA;
      --secondary-600: #3AAB9B;
      --text-900: #0F172B;
      --text-700: #314158;
      --text-500: #62748E;
      --text-200: #CDD5DF;
      --text-100: #E4E8ED;
      --bg-50: #F8FAFC;
      --white: #FFFFFF;
      --star: #F59E0B;
      --shadow-nav: 1px 2px 8px rgba(29,41,61,0.04), -1px 2px 8px rgba(29,41,61,0.04);
      --shadow-card: 0px 1px 4px rgba(29,41,61,0.06);
      --shadow-btn: 0px 1px 0.5px rgba(29,41,61,0.02);
    }

    .inner {
      max-width: 1280px;
      margin: 0 auto;
      padding: 0 80px;
    }

    html, body {
      font-family: 'Lato', sans-serif;
      background: var(--bg-50);
      color: var(--text-900);
      min-width: 1440px;
    }

    /* ─── HEADER ─────────────────────────────────────────── */
    .header {
      position: sticky;
      top: 0;
      width: 100%;
      height: 80px;
      background: var(--white);
      box-shadow: var(--shadow-nav);
      z-index: 100;
    }
    .header .inner {
      height: 100%;
      display: flex;
      align-items: center;
      justify-content: space-between;
    }
    .header-logo img {
      height: 32px;
      width: 125px;
      object-fit: contain;
      display: block;
    }
    .header-nav {
      display: flex;
      align-items: center;
      gap: 24px;
    }
    .nav-item {
      display: flex;
      align-items: center;
      gap: 4px;
      cursor: pointer;
      text-decoration: none;
    }
    .nav-item span {
      font-size: 14px;
      font-weight: 400;
      line-height: 20px;
      letter-spacing: 0.25px;
      color: var(--text-700);
      white-space: nowrap;
    }
    .nav-chevron {
      width: 16px;
      height: 16px;
      display: flex;
      align-items: center;
      justify-content: center;
      flex-shrink: 0;
    }
    .nav-chevron svg {
      width: 10px;
      height: 6px;
      fill: none;
      stroke: var(--text-700);
      stroke-width: 1.5;
    }
    .header-actions {
      display: flex;
      align-items: center;
      gap: 16px;
    }
    .btn-icon {
      width: 36px;
      height: 36px;
      border-radius: 12px;
      display: flex;
      align-items: center;
      justify-content: center;
      cursor: pointer;
      background: transparent;
      border: none;
      padding: 0;
    }
    .btn-icon svg {
      width: 20px;
      height: 20px;
      stroke: var(--text-900);
      fill: none;
      stroke-width: 1.5;
    }
    .btn-login {
      height: 40px;
      padding: 0 10px;
      border-radius: 16px;
      border: none;
      background: transparent;
      font-family: 'Lato', sans-serif;
      font-size: 14px;
      font-weight: 600;
      line-height: 20px;
      letter-spacing: 0.25px;
      color: var(--text-900);
      cursor: pointer;
      box-shadow: var(--shadow-btn);
      white-space: nowrap;
    }
    .btn-list {
      height: 40px;
      padding: 0 12px;
      border-radius: 12px;
      border: 1px solid var(--text-100);
      background: var(--white);
      font-family: 'Lato', sans-serif;
      font-size: 14px;
      font-weight: 600;
      line-height: 20px;
      letter-spacing: 0.25px;
      color: var(--text-900);
      cursor: pointer;
      box-shadow: var(--shadow-btn);
      white-space: nowrap;
    }

    /* ─── SEARCH STRIP ───────────────────────────────────── */
    .search-strip {
      padding: 24px 0;
    }
    .search-strip .inner {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 12px;
    }

    .search-pill {
      flex: 1;
      max-width: 580px;
      height: 52px;
      background: var(--white);
      border: 1px solid var(--text-100);
      border-radius: 14px;
      box-shadow: var(--shadow-nav);
      display: flex;
      align-items: center;
      padding-right: 8px;
    }

    .search-field {
      flex: 1;
      min-width: 0;
      display: flex;
      align-items: center;
      gap: 10px;
      padding: 0 16px;
    }

    .search-field-icon {
      flex-shrink: 0;
      width: 18px;
      height: 18px;
      color: var(--secondary-500);
    }

    .search-field-icon svg {
      width: 18px;
      height: 18px;
      stroke: var(--secondary-500);
      fill: none;
      stroke-width: 1.5;
    }

    .search-field-text {
      display: flex;
      flex-direction: column;
      gap: 1px;
      min-width: 0;
    }

    .search-field-label {
      font-size: 11px;
      font-weight: 400;
      line-height: 14px;
      letter-spacing: 0.4px;
      color: var(--text-500);
    }

    .search-field-value {
      display: flex;
      align-items: center;
      gap: 4px;
    }

    .search-field-value span {
      font-size: 14px;
      font-weight: 600;
      line-height: 20px;
      letter-spacing: 0.25px;
      color: var(--text-900);
      white-space: nowrap;
    }

    .search-field-value svg {
      width: 14px;
      height: 14px;
      stroke: var(--text-700);
      fill: none;
      stroke-width: 1.5;
    }

    .search-divider {
      width: 1px;
      height: 32px;
      background: var(--text-100);
      flex-shrink: 0;
    }

    .search-strip-btn {
      height: 44px;
      padding: 0 20px;
      border-radius: 10px;
      border: none;
      background: linear-gradient(156deg, var(--secondary-500) 0%, var(--secondary-600) 100%);
      font-family: 'Lato', sans-serif;
      font-size: 14px;
      font-weight: 600;
      color: var(--white);
      cursor: pointer;
      display: flex;
      align-items: center;
      gap: 6px;
      white-space: nowrap;
    }

    .search-strip-btn svg {
      width: 16px;
      height: 16px;
      stroke: var(--white);
      fill: none;
      stroke-width: 2;
    }

    /* ─── LAYOUT ──────────────────────────────────────────── */
    .page-body {
      padding: 24px 0;
    }
    .page-body .inner {
      display: grid;
      grid-template-columns: 280px 1fr;
      gap: 24px;
      align-items: flex-start;
    }

    /* ─── SIDEBAR ─────────────────────────────────────────── */
    .sidebar {
      min-width: 0;
      display: flex;
      flex-direction: column;
      gap: 16px;
      position: sticky;
      top: 80px;
      max-height: calc(100vh - 96px);
      overflow-y: auto;
    }

    .filter-panel {
      background: var(--white);
      border-radius: 16px;
      padding: 20px;
      display: flex;
      flex-direction: column;
      gap: 20px;
      box-shadow: var(--shadow-card);
    }

    .filter-title {
      font-size: 16px;
      font-weight: 700;
      line-height: 22px;
      color: var(--text-900);
    }

    .filter-section {
      display: flex;
      flex-direction: column;
      gap: 10px;
    }

    .filter-section-label {
      font-size: 13px;
      font-weight: 700;
      line-height: 18px;
      color: var(--text-900);
    }

    .chip-group {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
    }

    .filter-chip {
      height: 30px;
      padding: 0 10px;
      border-radius: 8px;
      border: 1px solid var(--text-100);
      background: var(--white);
      font-family: 'Lato', sans-serif;
      font-size: 12px;
      font-weight: 400;
      line-height: 16px;
      letter-spacing: 0.3px;
      color: var(--text-700);
      cursor: pointer;
      display: flex;
      align-items: center;
      white-space: nowrap;
    }

    .filter-chip.active {
      border-color: var(--text-700);
      color: var(--text-900);
      font-weight: 600;
      background: #F0F2F5;
    }

    /* UOM tabs */
    .uom-tabs {
      display: flex;
      background: var(--bg-50);
      border-radius: 8px;
      padding: 2px;
      border: 1px solid var(--text-100);
    }

    .uom-tab {
      flex: 1;
      height: 28px;
      border-radius: 6px;
      border: none;
      background: transparent;
      font-family: 'Lato', sans-serif;
      font-size: 12px;
      font-weight: 400;
      color: var(--text-500);
      cursor: pointer;
    }

    .uom-tab.active {
      background: var(--white);
      font-weight: 600;
      color: var(--text-900);
      box-shadow: 0px 1px 2px rgba(29,41,61,0.08);
    }

    /* Stepper */
    .stepper {
      display: flex;
      align-items: center;
      gap: 8px;
      border: 1px solid var(--text-100);
      border-radius: 10px;
      padding: 6px 10px;
      background: var(--white);
    }

    .stepper-btn {
      width: 24px;
      height: 24px;
      border-radius: 6px;
      border: 1px solid var(--text-100);
      background: var(--white);
      display: flex;
      align-items: center;
      justify-content: center;
      cursor: pointer;
      flex-shrink: 0;
    }

    .stepper-btn svg {
      width: 12px;
      height: 12px;
      stroke: var(--text-700);
      fill: none;
      stroke-width: 2;
    }

    .stepper-value {
      flex: 1;
      text-align: center;
      font-size: 14px;
      font-weight: 600;
      line-height: 20px;
      color: var(--text-900);
    }

    .stepper-unit {
      font-size: 12px;
      font-weight: 400;
      color: var(--text-500);
    }

    /* Duration pills */
    .duration-pills {
      display: flex;
      gap: 6px;
    }

    .duration-pill {
      flex: 1;
      height: 28px;
      border-radius: 8px;
      border: 1px solid var(--text-100);
      background: var(--white);
      font-family: 'Lato', sans-serif;
      font-size: 12px;
      font-weight: 400;
      color: var(--text-700);
      cursor: pointer;
      display: flex;
      align-items: center;
      justify-content: center;
      white-space: nowrap;
    }

    .duration-pill.active {
      background: var(--white);
      border-color: var(--secondary-500);
      color: var(--secondary-600);
      font-weight: 600;
    }

    /* Filter actions */
    .filter-actions {
      display: flex;
      gap: 8px;
    }

    .btn-reset {
      flex: 1;
      height: 36px;
      border-radius: 10px;
      border: 1px solid var(--text-100);
      background: var(--white);
      font-family: 'Lato', sans-serif;
      font-size: 13px;
      font-weight: 600;
      color: var(--text-700);
      cursor: pointer;
    }

    .btn-apply {
      flex: 1;
      height: 36px;
      border-radius: 10px;
      border: none;
      background: linear-gradient(156deg, var(--secondary-500) 0%, var(--secondary-600) 100%);
      font-family: 'Lato', sans-serif;
      font-size: 13px;
      font-weight: 600;
      color: var(--white);
      cursor: pointer;
    }

    /* Concierge card in sidebar */
    .sidebar-concierge {
      background: var(--white);
      border-radius: 16px;
      padding: 20px;
      box-shadow: var(--shadow-card);
      display: flex;
      flex-direction: column;
      gap: 10px;
    }

    .sidebar-concierge h4 {
      font-size: 14px;
      font-weight: 700;
      line-height: 20px;
      color: var(--text-900);
    }

    .sidebar-concierge p {
      font-size: 12px;
      font-weight: 400;
      line-height: 18px;
      color: var(--text-500);
    }

    .btn-get-matched {
      width: 100%;
      height: 36px;
      border-radius: 10px;
      border: 1px solid var(--text-100);
      background: var(--white);
      font-family: 'Lato', sans-serif;
      font-size: 13px;
      font-weight: 600;
      color: var(--text-900);
      cursor: pointer;
    }

    /* ─── LISTINGS MAIN ───────────────────────────────────── */
    .listings-main {
      flex: 1;
      min-width: 0;
      display: flex;
      flex-direction: column;
      gap: 12px;
    }

    .listings-header {
      display: flex;
      align-items: flex-start;
      justify-content: space-between;
    }

    .listings-title {
      font-size: 20px;
      font-weight: 700;
      line-height: 28px;
      color: var(--text-900);
    }

    .listings-subtitle {
      font-size: 12px;
      font-weight: 400;
      line-height: 16px;
      letter-spacing: 0.4px;
      color: var(--text-500);
      margin-top: 2px;
    }

    .sort-dropdown {
      display: flex;
      align-items: center;
      gap: 6px;
      cursor: pointer;
      background: var(--white);
      border: 1px solid var(--text-100);
      font-family: 'Lato', sans-serif;
      padding: 8px 14px;
      border-radius: 10px;
      box-shadow: var(--shadow-btn);
      height: 36px;
    }

    .sort-dropdown span {
      font-size: 13px;
      font-weight: 400;
      line-height: 18px;
      color: var(--text-700);
    }

    .sort-dropdown strong {
      font-size: 13px;
      font-weight: 600;
      color: var(--text-900);
    }

    .sort-dropdown svg {
      width: 14px;
      height: 14px;
      stroke: var(--text-700);
      fill: none;
      stroke-width: 1.5;
    }

    /* ─── WAREHOUSE CARD ──────────────────────────────────── */
    .card {
      background: var(--white);
      border-radius: 16px;
      box-shadow: var(--shadow-card);
      display: flex;
      overflow: hidden;
      min-height: 140px;
    }

    .card-image-wrap {
      position: relative;
      width: 200px;
      flex-shrink: 0;
    }

    .card-image-wrap img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
    }

    /* Move-in badge */
    .move-badge {
      position: absolute;
      top: 10px;
      left: 10px;
      height: 24px;
      border-radius: 8px;
      padding: 0 8px;
      display: flex;
      align-items: center;
      gap: 4px;
      font-size: 11px;
      font-weight: 600;
      line-height: 1;
      white-space: nowrap;
    }

    .move-badge.instant {
      background: rgba(255,255,255,0.92);
      color: var(--secondary-500);
      border: 1px solid rgba(64,188,170,0.25);
    }

    .move-badge.standard {
      background: rgba(255,255,255,0.92);
      color: var(--text-700);
      border: 1px solid var(--text-100);
    }

    .move-badge svg {
      width: 12px;
      height: 12px;
    }

    .move-badge.instant svg { fill: var(--secondary-500); stroke: none; }
    .move-badge.standard svg { stroke: var(--text-700); fill: none; stroke-width: 1.5; }

    /* Heart */
    .card-heart {
      position: absolute;
      top: 10px;
      right: 10px;
      width: 32px;
      height: 32px;
      border-radius: 50%;
      background: rgba(255,255,255,0.92);
      border: none;
      display: flex;
      align-items: center;
      justify-content: center;
      cursor: pointer;
      box-shadow: 0 1px 2px rgba(0,0,0,0.08);
    }

    .card-heart svg {
      width: 16px;
      height: 16px;
      stroke: var(--text-700);
      fill: none;
      stroke-width: 1.5;
    }

    /* Nav arrows */
    .card-arrow {
      position: absolute;
      top: 50%;
      transform: translateY(-50%);
      width: 26px;
      height: 26px;
      border-radius: 50%;
      background: rgba(255,255,255,0.85);
      border: none;
      display: flex;
      align-items: center;
      justify-content: center;
      cursor: pointer;
    }

    .card-arrow svg {
      width: 12px;
      height: 12px;
      stroke: var(--text-900);
      fill: none;
      stroke-width: 2;
    }

    .card-arrow.prev { left: 8px; }
    .card-arrow.next { right: 8px; }

    /* Card body */
    .card-body {
      flex: 1;
      min-width: 0;
      padding: 16px 20px;
      display: flex;
      gap: 16px;
    }

    .card-info {
      flex: 1;
      min-width: 0;
      display: flex;
      flex-direction: column;
      gap: 8px;
    }

    .card-name {
      font-size: 18px;
      font-weight: 700;
      line-height: 24px;
      letter-spacing: 0.1px;
      color: var(--text-900);
    }

    .card-rating {
      display: flex;
      align-items: center;
      gap: 4px;
    }

    .card-rating .star {
      color: var(--star);
      font-size: 14px;
    }

    .card-rating .score {
      font-size: 13px;
      font-weight: 600;
      color: var(--text-900);
      line-height: 18px;
    }

    .card-rating .reviews {
      font-size: 13px;
      font-weight: 400;
      color: var(--text-500);
      line-height: 18px;
    }

    .card-tags {
      display: flex;
      align-items: center;
      gap: 6px;
      flex-wrap: wrap;
    }

    .tag {
      font-size: 13px;
      font-weight: 400;
      color: var(--text-700);
      line-height: 18px;
    }

    .tag-dot {
      width: 3px;
      height: 3px;
      border-radius: 50%;
      background: var(--text-200);
      flex-shrink: 0;
    }

    /* Card pricing */
    .card-pricing {
      flex-shrink: 0;
      display: flex;
      flex-direction: column;
      align-items: flex-end;
      gap: 4px;
    }

    .price-main {
      font-size: 24px;
      font-weight: 700;
      line-height: 30px;
      color: var(--text-900);
    }

    .price-unit {
      font-size: 12px;
      font-weight: 400;
      color: var(--text-500);
      line-height: 16px;
    }

    .price-total {
      font-size: 12px;
      font-weight: 400;
      color: var(--text-500);
      line-height: 16px;
    }

    .card-actions {
      display: flex;
      gap: 8px;
      margin-top: auto;
      padding-top: 8px;
      align-self: flex-end;
    }

    .btn-compare {
      height: 36px;
      padding: 0 16px;
      border-radius: 10px;
      border: 1px solid var(--text-100);
      background: var(--white);
      font-family: 'Lato', sans-serif;
      font-size: 13px;
      font-weight: 600;
      color: var(--text-900);
      cursor: pointer;
    }

    .btn-view {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      height: 36px;
      padding: 0 20px;
      border-radius: 10px;
      border: none;
      background: linear-gradient(156deg, var(--secondary-500) 0%, var(--secondary-600) 100%);
      font-family: 'Lato', sans-serif;
      font-size: 13px;
      font-weight: 600;
      color: var(--white);
      cursor: pointer;
      text-decoration: none;
    }

    /* ─── INLINE CONCIERGE BANNER ─────────────────────────── */
    .inline-concierge {
      background: #F0FAF8;
      border-radius: 16px;
      padding: 20px 24px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 16px;
      border: 1px solid #D4EDE7;
    }

    .inline-concierge-text h4 {
      font-size: 15px;
      font-weight: 700;
      color: var(--text-900);
      line-height: 22px;
    }

    .inline-concierge-text p {
      font-size: 13px;
      font-weight: 400;
      color: var(--text-500);
      line-height: 18px;
      margin-top: 2px;
    }

    .inline-concierge-text p span {
      color: var(--secondary-500);
    }

    .btn-inline-matched {
      height: 40px;
      padding: 0 20px;
      border-radius: 10px;
      border: 1px solid var(--secondary-500);
      background: var(--white);
      font-family: 'Lato', sans-serif;
      font-size: 13px;
      font-weight: 600;
      color: var(--secondary-600);
      cursor: pointer;
      white-space: nowrap;
      flex-shrink: 0;
    }

  /* ─── FOOTER ──────────────────────────────── */
  .footer .inner { max-width: 1280px; margin: 0 auto; padding: 0 80px; }
  .footer { background: var(--text-900); padding: 80px 0 32px; color: rgba(255,255,255,0.7); }
  .footer-grid { display: grid; grid-template-columns: 1.4fr 1fr 1.2fr 1.2fr 1fr 1fr; gap: 48px; margin-bottom: 64px; }
  .footer-brand { display: flex; flex-direction: column; gap: 20px; }
  .footer-logo { display: flex; align-items: center; gap: 8px; font-size: 28px; font-weight: 700; color: #fff; letter-spacing: -0.5px; }
  .footer-tagline { font-size: 16px; color: rgba(255,255,255,0.55); line-height: 1.5; max-width: 260px; }
  .footer-cities { display: flex; flex-wrap: wrap; gap: 8px; max-width: 280px; }
  .footer-city-chip { display: inline-flex; align-items: center; padding: 8px 14px; background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.12); border-radius: 999px; font-size: 14px; color: rgba(255,255,255,0.85); text-decoration: none; transition: border-color .12s, background .12s, color .12s; }
  .footer-city-chip:hover { border-color: var(--secondary-500); background: rgba(64,188,170,0.1); color: #fff; }
  .footer-col-title { font-size: 12px; font-weight: 700; letter-spacing: 1.5px; text-transform: uppercase; color: rgba(255,255,255,0.45); margin-bottom: 24px; }
  .footer-link { display: block; font-size: 16px; color: rgba(255,255,255,0.75); padding: 8px 0; text-decoration: none; transition: color .12s; }
  .footer-link:hover { color: var(--secondary-500); }
