---
import BaseLayout from "../layouts/BaseLayout.astro";
import Navbar from "../components/layout/Navbar.astro";
import Footer from "../components/layout/Footer.astro";
import Hero from "../components/marketing/Hero.tsx";
import ValueProps from "../components/marketing/ValueProps.astro";
import HowItWorks from "../components/marketing/HowItWorks.astro";
import ClientLogos from "../components/marketing/ClientLogos.astro";
import ClosingCta from "../components/marketing/ClosingCta.astro";
---
<BaseLayout title="Cargoz — Warehouse marketplace UAE">
  <Navbar />
  <main>
    <Hero client:load />
    <ClientLogos />
    <ValueProps />
    <HowItWorks />
    <ClosingCta />
  </main>
  <Footer />
</BaseLayout>
