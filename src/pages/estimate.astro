<script is:inline>
  (function(){
    const viewport = document.getElementById('pdfViewport');
    const pages = viewport.querySelectorAll('.pdf-page-wrap');
    const pageEls = viewport.querySelectorAll('.pdf-page');
    const pageInput = document.getElementById('pdfPageInput');
    const prevBtn = document.getElementById('pdfPrev');
    const nextBtn = document.getElementById('pdfNext');
    const zoomOut = document.getElementById('pdfZoomOut');
    const zoomIn = document.getElementById('pdfZoomIn');
    const zoomLabel = document.getElementById('pdfZoomLabel');

    const ZOOM_STEPS = [0.5, 0.7344, 0.9, 1.1, 1.4];
    let zoomIdx = 1;
    let currentPage = 1;

    function applyZoom() {
      const scale = ZOOM_STEPS[zoomIdx];
      pages.forEach(w => { w.style.setProperty('--pdf-scale', scale); });
      const pct = Math.round(scale * 100);
      zoomLabel.textContent = pct + '%';
      zoomOut.disabled = zoomIdx === 0;
      zoomIn.disabled = zoomIdx === ZOOM_STEPS.length - 1;
    }

    function goToPage(n) {
      n = Math.max(1, Math.min(pages.length, n));
      currentPage = n;
      const target = pages[n - 1];
      target.scrollIntoView({ behavior: 'smooth', block: 'start' });
      pageInput.value = n;
      prevBtn.disabled = n === 1;
      nextBtn.disabled = n === pages.length;
    }

    prevBtn.addEventListener('click', () => goToPage(currentPage - 1));
    nextBtn.addEventListener('click', () => goToPage(currentPage + 1));
    zoomOut.addEventListener('click', () => { if (zoomIdx > 0) { zoomIdx--; applyZoom(); }});
    zoomIn.addEventListener('click', () => { if (zoomIdx < ZOOM_STEPS.length - 1) { zoomIdx++; applyZoom(); }});

    pageInput.addEventListener('change', () => {
      const n = parseInt(pageInput.value, 10);
      if (!isNaN(n)) goToPage(n);
      else pageInput.value = currentPage;
    });
    pageInput.addEventListener('keydown', (e) => {
      if (e.key === 'Enter') { e.preventDefault(); pageInput.blur(); }
    });

    // Track current page on scroll
    viewport.addEventListener('scroll', () => {
      const viewportTop = viewport.scrollTop + viewport.clientHeight / 3;
      let best = 1;
      pages.forEach((p, i) => {
        if (p.offsetTop <= viewportTop) best = i + 1;
      });
      if (best !== currentPage) {
        currentPage = best;
        pageInput.value = best;
        prevBtn.disabled = best === 1;
        nextBtn.disabled = best === pages.length;
      }
    });

    applyZoom();
    goToPage(1);
  })();
</script>

