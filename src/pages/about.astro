---
---
<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>About us — Cargoz</title>
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link rel="stylesheet" href="/styles/tokens.css" />
<link rel="stylesheet" href="/styles/utilities.css" />
<style is:global>
  :root {
    --primary-500: #40BCAA;
    --primary-600: #3AAB9B;
    --green-500: #00B26F;
    --text-900: #0F172B;
    --text-700: #314158;
    --text-500: #62748E;
    --text-300: #90A1B9;
    --text-100: #E4E8ED;
    --text-50: #F5F7FA;
    --text-25: #F9FBFC;
    --white: #FFFFFF;
    --teal-tint-1: #F2FFFE;
    --teal-tint-2: #F2FAF9;
    --teal-border: #D0EDE8;
    --gradient-teal: linear-gradient(135deg, #F2FFFE 0%, #F2FAF9 100%);
    --shadow-xs: 0 1px 2px rgba(29,41,61,0.05);
    --shadow-card: 0 1px 3px rgba(29,41,61,0.06), 0 4px 12px rgba(29,41,61,0.04);
    --shadow-hover: 0 4px 16px rgba(29,41,61,0.1);
    --shadow-nav: 1px 2px 8px 0 rgba(29,41,61,0.04), -1px 2px 8px 0 rgba(29,41,61,0.04);
    --shadow-btn: 0 1px 0.5px 0 rgba(29,41,61,0.02);
    --inner: 1280px;
  }
  * { box-sizing: border-box; margin: 0; padding: 0; }
  body {
    font-family: 'Lato', sans-serif;
    background: var(--white);
    color: var(--text-900);
    min-width: 1440px;
    -webkit-font-smoothing: antialiased;
    position: relative;
  }
  body::before {
    content: '';
    position: fixed;
    inset: 0;
    z-index: -1;
    pointer-events: none;
    background:
      radial-gradient(40% 35% at 8% 12%, rgba(64,188,170,0.10), transparent 70%),
      radial-gradient(45% 40% at 92% 22%, rgba(121,87,255,0.07), transparent 70%),
      radial-gradient(45% 40% at 12% 78%, rgba(121,87,255,0.07), transparent 70%),
      radial-gradient(40% 35% at 88% 88%, rgba(64,188,170,0.10), transparent 70%);
  }
  a { text-decoration: none; color: inherit; }
  button { font-family: inherit; border: none; background: none; cursor: pointer; }

  /* ─── SHARED ──────────────────────────────── */
  .inner {
    max-width: var(--inner);
    margin: 0 auto;
    padding: 0 80px;
  }
  .eyebrow {
    font-size: 11px; font-weight: 700;
    letter-spacing: 2.5px; text-transform: uppercase;
    color: var(--primary-500);
    margin-bottom: 12px;
  }
  .eyebrow.light { color: rgba(255,255,255,0.6); }
  .h1 {
    font-size: 60px; font-weight: 700;
    color: var(--text-900);
    line-height: 1.08;
    letter-spacing: -1px;
  }
  .h2 {
    font-size: 44px; font-weight: 700;
    color: var(--text-900);
    line-height: 1.1;
    letter-spacing: -0.5px;
  }
  .h2.light { color: var(--white); }
  .lead {
    font-size: 18px; font-weight: 400;
    color: var(--text-500);
    line-height: 1.65;
    max-width: 540px;
  }
  .lead.light { color: rgba(255,255,255,0.7); }

  /* ─── HEADER (shared across pages) ─────────────────── */
  .header {
    position: sticky;
    top: 0;
    width: 100%;
    height: 80px;
    background: var(--white);
    box-shadow: var(--shadow-nav);
    z-index: 100;
  }
  .header .inner {
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  .header-logo img { height: 32px; width: 125px; object-fit: contain; display: block; }
  .header-nav { display: flex; align-items: center; gap: 24px; }
  .nav-item { display: flex; align-items: center; gap: 4px; cursor: pointer; text-decoration: none; }
  .nav-item span { font-size: 14px; font-weight: 400; line-height: 20px; letter-spacing: 0.25px; color: var(--text-700); white-space: nowrap; }
  .nav-chevron { width: 16px; height: 16px; display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
  .nav-chevron svg { width: 10px; height: 6px; fill: none; stroke: var(--text-700); stroke-width: 1.5; }
  .header-actions { display: flex; align-items: center; gap: 16px; }
  .btn-icon { width: 36px; height: 36px; border-radius: 12px; display: flex; align-items: center; justify-content: center; cursor: pointer; background: transparent; border: none; padding: 0; }
  .btn-icon svg { width: 20px; height: 20px; stroke: var(--text-900); fill: none; stroke-width: 1.5; }
  .btn-login { height: 40px; padding: 0 10px; border-radius: 16px; border: none; background: transparent; font-family: 'Lato', sans-serif; font-size: 14px; font-weight: 600; line-height: 20px; letter-spacing: 0.25px; color: var(--text-900); cursor: pointer; box-shadow: var(--shadow-btn); white-space: nowrap; }
  .btn-list { height: 40px; padding: 0 12px; border-radius: 12px; border: 1px solid var(--text-100); background: var(--white); font-family: 'Lato', sans-serif; font-size: 14px; font-weight: 600; line-height: 20px; letter-spacing: 0.25px; color: var(--text-900); cursor: pointer; box-shadow: var(--shadow-btn); white-space: nowrap; }

  /* ─── BUTTONS ─────────────────────────────── */
  .btn-primary {
    height: 52px; padding: 0 28px;
    background: var(--primary-500);
    color: var(--white);
    border-radius: 14px;
    font-size: 15px; font-weight: 700;
    display: inline-flex; align-items: center; gap: 8px;
    transition: background .15s;
  }
  .btn-primary:hover { background: var(--primary-600); }
  .btn-secondary {
    height: 52px; padding: 0 28px;
    background: var(--white);
    border: 1.5px solid var(--text-100);
    color: var(--text-900);
    border-radius: 14px;
    font-size: 15px; font-weight: 700;
    display: inline-flex; align-items: center; gap: 8px;
    transition: border-color .15s;
  }
  .btn-secondary:hover { border-color: var(--primary-500); }
  .btn-dark {
    height: 52px; padding: 0 28px;
    background: var(--white);
    color: var(--text-900);
    border-radius: 14px;
    font-size: 15px; font-weight: 700;
    display: inline-flex; align-items: center; gap: 8px;
  }
  .btn-wa {
    height: 52px; padding: 0 28px;
    background: var(--green-500);
    color: var(--white);
    border-radius: 14px;
    font-size: 15px; font-weight: 700;
    display: inline-flex; align-items: center; gap: 8px;
  }

  /* ─── 01 HERO (ClickUp-style scattered portraits) ─── */
  .sec-hero {
    background: transparent;
    padding: 80px 0 80px;
  }
  .hero-center {
    display: flex; flex-direction: column; align-items: center;
    text-align: center;
    gap: 24px;
    margin-bottom: 48px;
  }
  .hero-h1 {
    font-size: 76px; font-weight: 700;
    color: var(--text-900);
    line-height: 1.05;
    letter-spacing: -2px;
    margin: 0;
  }
  .hero-h1 em {
    font-style: normal;
    background: linear-gradient(135deg, #40BCAA 0%, #7957FF 100%);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    color: transparent;
  }
  .hero-lead {
    font-size: 20px; color: var(--text-500);
    line-height: 1.5; max-width: 620px;
    margin: 0;
  }
  .hero-cta-pill {
    display: inline-flex; align-items: center; gap: 12px;
    background: var(--text-900);
    color: var(--white);
    padding: 14px 24px 14px 14px;
    border-radius: 100px;
    font-size: 15px; font-weight: 600;
    text-decoration: none;
    transition: background .15s, transform .15s;
    margin-top: 8px;
  }
  .hero-cta-pill:hover {
    background: #1E293B;
    transform: translateY(-1px);
  }
  .hero-cta-pill .play-dot {
    width: 28px; height: 28px;
    background: var(--primary-500);
    border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
  }

  .portrait-grid {
    position: relative;
    display: grid;
    grid-template-columns: 1fr 1fr 1.4fr 1fr 1fr;
    grid-template-rows: 1fr 1fr;
    column-gap: 18px;
    row-gap: 16px;
    max-width: 1200px;
    margin: 0 auto;
    padding-bottom: 56px;
  }
  .portrait {
    border-radius: 20px;
    background-size: cover;
    background-position: center top;
    background-repeat: no-repeat;
    aspect-ratio: 4/5;
    overflow: hidden;
  }
  .portrait.big {
    grid-column: 3;
    grid-row: 1 / span 2;
    aspect-ratio: auto;
    height: 100%;
    align-self: stretch;
    border-radius: 24px;
  }
  /* ClickUp pattern: cols 2 & 4 drop down, cols 1, 3, 5 stay anchored top */
  .portrait-grid > .portrait:nth-child(2),
  .portrait-grid > .portrait:nth-child(4),
  .portrait-grid > .portrait:nth-child(7),
  .portrait-grid > .portrait:nth-child(8) {
    transform: translateY(48px);
  }

  .hero-trusted {
    display: flex; align-items: center; gap: 48px;
    padding-top: 56px;
    margin-top: 48px;
    border-top: 1px solid var(--text-100);
    flex-wrap: wrap;
    justify-content: center;
  }
  .hero-trusted-label {
    font-size: 11px; font-weight: 700;
    letter-spacing: 3px; text-transform: uppercase;
    color: var(--text-500);
    white-space: nowrap;
  }
  .hero-trusted-logos {
    display: flex; align-items: center; gap: 48px;
    flex-wrap: wrap; justify-content: center;
  }
  .hero-trusted-logos span {
    font-size: 18px; font-weight: 700;
    color: var(--text-500);
    opacity: 0.7;
    letter-spacing: -0.3px;
  }
  .hero-img-label {
    display: none;
  }

  /* ─── 02 STATS STRIP (Amplitude-style oversized, in card) ─── */
  .sec-stats {
    background: transparent;
    padding: 64px 0;
  }
  .stats-card {
    background: var(--text-25);
    border: 1px solid var(--text-100);
    border-radius: 24px;
    padding: 64px 56px;
  }
  .stats-row {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 48px;
  }
  .stat-block {
    display: flex; flex-direction: column;
    align-items: center; gap: 16px;
    text-align: center;
    position: relative;
  }
  .stat-num {
    font-size: 88px; font-weight: 700;
    color: var(--primary-500);
    line-height: 0.95;
    letter-spacing: -3.5px;
  }
  .stat-label {
    font-size: 11px; font-weight: 700;
    color: var(--text-700);
    letter-spacing: 2px;
    text-transform: uppercase;
  }
  .stat-sub {
    font-size: 15px;
    color: var(--text-500);
    line-height: 1.5;
    margin-top: -8px;
    max-width: 240px;
  }

  /* ─── 03 STORY ────────────────────────────── */
  .sec-story {
    background: transparent;
    padding: 96px 0;
  }
  .story-layout {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 80px;
    text-align: center;
  }
  .story-left { display: flex; flex-direction: column; gap: 48px; }
  .story-right { display: flex; flex-direction: column; gap: 48px; }

  .story-heading-block {
    display: flex; flex-direction: column; align-items: center;
    gap: 20px; max-width: 720px;
  }
  .story-heading-block .h2 {
    font-size: 56px; line-height: 1.05;
    letter-spacing: -1.5px;
    text-align: center;
  }
  .story-heading-block .h2 em {
    font-style: normal;
    color: var(--primary-500);
  }
  .story-heading-block .lead {
    max-width: 560px !important;
    text-align: center;
    font-size: 18px;
  }
  .story-proof-row {
    display: flex; gap: 32px;
    padding: 20px 0 4px;
    border-top: 1px solid var(--text-100);
  }
  .story-proof-item { display: flex; flex-direction: column; gap: 2px; }
  .story-proof-num {
    font-size: 28px; font-weight: 700;
    color: var(--primary-500);
    line-height: 1;
    letter-spacing: -0.5px;
  }
  .story-proof-label {
    font-size: 12px; color: var(--text-500);
    font-weight: 500;
  }

  .story-chunks {
    display: flex; flex-direction: column; gap: 8px;
  }
  .story-chunk {
    display: grid;
    grid-template-columns: 56px 1fr;
    gap: 20px;
    padding: 24px 0;
    border-top: 1px solid var(--text-100);
    align-items: start;
  }
  .story-chunk:last-child { border-bottom: 1px solid var(--text-100); }
  .story-chunk-num {
    font-size: 32px; font-weight: 700;
    color: var(--primary-500);
    line-height: 1;
    letter-spacing: -1px;
    font-variant-numeric: tabular-nums;
    padding-top: 2px;
  }
  .story-chunk-body-wrap {
    display: flex; flex-direction: column; gap: 8px;
  }
  .story-chunk-label {
    font-size: 11px; font-weight: 700;
    letter-spacing: 2px; text-transform: uppercase;
    color: var(--text-500);
  }
  .story-chunk-title {
    font-size: 22px; font-weight: 700;
    color: var(--text-900); line-height: 1.3;
  }
  .story-chunk-body {
    font-size: 15px; color: var(--text-500);
    line-height: 1.65;
    margin-top: 4px;
  }

  .story-right { display: flex; flex-direction: column; gap: 28px; }
  .pull-quote {
    background: none;
    border: none;
    padding: 40px 0 0;
    max-width: 900px;
    display: flex; flex-direction: column; align-items: center;
    gap: 20px;
    position: relative;
  }
  .pull-quote-mark {
    position: absolute;
    top: 0; left: 50%;
    transform: translateX(-50%);
    font-family: Georgia, serif;
    font-size: 240px;
    line-height: 1;
    color: var(--primary-500);
    opacity: 0.15;
    pointer-events: none;
    user-select: none;
    z-index: 0;
  }
  .pull-quote-text {
    position: relative; z-index: 1;
    font-size: 40px; font-weight: 600;
    color: var(--text-900);
    line-height: 1.3; font-style: italic;
    letter-spacing: -0.5px;
    margin: 0;
    text-align: center;
  }
  .pull-quote-cite {
    font-size: 13px; color: var(--text-500);
    font-weight: 500;
    letter-spacing: 0.3px;
  }
  .pull-quote-cite::before { display: none; }

  /* Funding timeline */
  .investors-wrap {
    display: flex; flex-direction: column; align-items: center;
    gap: 32px;
    width: 100%;
    max-width: 960px;
  }
  .timeline-head {
    font-size: 11px; font-weight: 700;
    letter-spacing: 3px; text-transform: uppercase;
    color: var(--text-500);
    margin: 0;
  }
  .funding-timeline {
    display: flex;
    width: 100%;
    align-items: flex-start;
    position: relative;
  }
  .timeline-item {
    flex: 1;
    display: flex; flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 12px;
    position: relative;
  }
  /* Horizontal line between dots */
  .timeline-item:not(:last-child)::after {
    content: '';
    position: absolute;
    top: 7px;
    left: 50%; right: 0;
    height: 2px;
    background: var(--teal-border);
    z-index: 0;
  }
  .timeline-item:not(:first-child)::before {
    content: '';
    position: absolute;
    top: 7px;
    right: 50%; left: 0;
    height: 2px;
    background: var(--teal-border);
    z-index: 0;
  }
  .timeline-left {
    display: flex; justify-content: center;
    position: relative; z-index: 1;
    width: 16px; height: 16px;
    flex-shrink: 0;
  }
  .timeline-dot {
    width: 16px; height: 16px;
    background: var(--white);
    border-radius: 50%;
    border: 3px solid var(--primary-500);
    box-shadow: 0 0 0 4px var(--white);
    position: relative; z-index: 1;
  }
  .timeline-line { display: none; }
  .timeline-content {
    display: flex; flex-direction: column; align-items: center;
    gap: 6px;
  }
  .timeline-date {
    font-size: 11px; font-weight: 700;
    letter-spacing: 2px; text-transform: uppercase;
    color: var(--primary-500);
  }
  .timeline-title {
    font-size: 18px; font-weight: 700;
    color: var(--text-900);
    letter-spacing: -0.2px;
  }
  .timeline-by {
    font-size: 13px; color: var(--text-500);
  }
  .investor-chip {
    display: inline-flex; align-items: center;
    font-size: 12px; font-weight: 600;
    color: var(--text-700);
    background: var(--white);
    border: 1px solid var(--text-100);
    border-radius: 100px;
    padding: 5px 12px;
    margin-top: 4px;
    align-self: flex-start;
  }

  .linkedin-row { display: flex; gap: 12px; }
  .linkedin-btn {
    flex: 1;
    height: 60px;
    background: var(--white);
    border: 1px solid var(--text-100);
    border-radius: 14px;
    padding: 0 18px;
    display: flex; align-items: center; gap: 14px;
    box-shadow: var(--shadow-xs);
    color: var(--text-900);
    transition: border-color .15s, box-shadow .15s;
  }
  .linkedin-btn:hover {
    border-color: var(--primary-500);
    box-shadow: var(--shadow-card);
  }
  .li-icon {
    width: 36px; height: 36px;
    background: #0A66C2;
    border-radius: 8px;
    display: flex; align-items: center; justify-content: center;
    color: #fff; font-weight: 800; font-size: 14px;
    flex-shrink: 0;
  }
  .li-meta { flex: 1; }
  .li-name { font-size: 14px; font-weight: 700; color: var(--text-900); }
  .li-role { font-size: 12px; color: var(--text-500); margin-top: 1px; }
  .li-arrow { color: var(--text-300); }

  /* ─── 04 FOUNDERS PHOTOS ──────────────────── */
  .sec-founders {
    background: transparent;
    padding: 96px 0;
  }
  .duo-strip {
    width: 100%;
    height: 440px;
    background: linear-gradient(145deg, #D4F0EB, #9BDDD3);
    border-radius: 24px;
    display: flex; align-items: center; justify-content: center;
    position: relative; overflow: hidden;
    margin-bottom: 28px;
  }
  .duo-strip::before {
    content: '';
    position: absolute; inset: 24px;
    border: 1.5px dashed rgba(255,255,255,0.5);
    border-radius: 16px;
  }
  .photo-label {
    background: rgba(255,255,255,0.9);
    backdrop-filter: blur(6px);
    padding: 8px 16px;
    border-radius: 100px;
    font-size: 13px; font-weight: 600;
    color: var(--text-700); z-index: 1;
  }
  /* People grid — all 4 in equal columns */
  .people-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 20px;
    align-items: start;
  }
  .person-card {
    border-radius: 20px;
    padding: 16px 16px 24px;
    display: flex; flex-direction: column;
    transition: box-shadow .2s, transform .2s;
  }
  .person-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 16px 40px rgba(15,23,43,0.1);
  }
  .person-card.is-founder {
    background: var(--white);
    border: 1px solid var(--text-100);
  }
  .person-card.is-leader {
    background: var(--white);
    border: 1px solid var(--text-100);
  }
  .person-photo {
    width: 100%;
    aspect-ratio: 3/4;
    background-size: cover;
    background-position: center top;
    background-repeat: no-repeat;
    border-radius: 12px;
    background-color: var(--text-25);
  }
  .founder-role-chip {
    align-self: flex-start;
    background: var(--white);
    color: var(--primary-600);
    font-size: 10px; font-weight: 700;
    letter-spacing: 2px; text-transform: uppercase;
    padding: 5px 10px;
    border-radius: 100px;
    border: 1px solid var(--teal-border);
    margin-top: 16px;
  }
  .is-leader .founder-role-chip {
    background: var(--text-25);
    color: var(--text-500);
    border-color: var(--text-100);
  }
  .founder-name {
    font-size: 20px; font-weight: 700;
    color: var(--text-900); line-height: 1.2;
    margin-top: 8px;
  }
  .founder-bio {
    font-size: 13px; color: var(--text-500);
    line-height: 1.6; margin-top: 8px;
  }
  .founder-li {
    display: inline-flex; align-items: center; gap: 8px;
    margin-top: 14px;
    padding: 8px 14px;
    background: var(--white);
    border: 1px solid var(--teal-border);
    border-radius: 100px;
    color: var(--text-900);
    text-decoration: none;
    font-size: 12px; font-weight: 600;
    align-self: flex-start;
    transition: border-color .15s, color .15s;
  }
  .founder-li:hover { border-color: var(--primary-500); color: var(--primary-600); }

  /* keep old selectors as aliases so nothing breaks */
  .founder-cards, .leaders-row { display: none; }
  .founder-card, .leader-card, .leader-photo, .leader-info,
  .leader-role, .leader-name, .leader-meta { display: none; }

  /* ─── 05 TEAM (polaroid fan) ─────────────── */
  .sec-team {
    background: transparent;
    padding: 96px 0 120px;
  }
  .team-polaroids {
    position: relative;
    height: 520px;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-top: 40px;
  }
  .polaroid {
    position: absolute;
    background: var(--white);
    padding: 18px 18px 0;
    box-shadow: 0 16px 40px rgba(15,23,43,0.14), 0 4px 12px rgba(15,23,43,0.08);
    width: 580px;
    border-radius: 2px;
    transition: transform .3s ease, box-shadow .3s ease, z-index 0s;
    cursor: pointer;
