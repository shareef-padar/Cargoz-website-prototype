---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>WH-100279 in Al Khabaisi — Cargoz</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link rel="stylesheet" href="/styles/tokens.css" />
  <link rel="stylesheet" href="/styles/utilities.css" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --primary-500: #7957FF;
      --secondary-500: #40BCAA;
      --secondary-600: #3AAB9B;
      --text-900: #0F172B;
      --text-700: #314158;
      --text-500: #62748E;
      --text-200: #CDD5DF;
      --text-100: #E4E8ED;
      --bg-50: #F8FAFC;
      --white: #FFFFFF;
      --star: #F59E0B;
      --shadow-nav: 1px 2px 8px rgba(29,41,61,0.04), -1px 2px 8px rgba(29,41,61,0.04);
      --shadow-card: 0px 1px 4px rgba(29,41,61,0.06);
      --shadow-btn: 0px 1px 0.5px rgba(29,41,61,0.02);
    }

    .inner {
      max-width: 1280px;
      margin: 0 auto;
      padding: 0 80px;
    }

    html, body {
      font-family: 'Lato', sans-serif;
      background: var(--bg-50);
      color: var(--text-900);
      min-width: 1440px;
    }

    /* ─── HEADER (shared across pages) ─────────────────── */
    .header {
      position: sticky;
      top: 0;
      width: 100%;
      height: 80px;
      background: var(--white);
      box-shadow: var(--shadow-nav);
      z-index: 100;
    }
    .header .inner {
      height: 100%;
      display: flex;
      align-items: center;
      justify-content: space-between;
    }
    .header-logo img { height: 32px; width: 125px; object-fit: contain; display: block; }
    .header-nav { display: flex; align-items: center; gap: 24px; }
    .nav-item { display: flex; align-items: center; gap: 4px; cursor: pointer; text-decoration: none; }
    .nav-item span { font-size: 14px; font-weight: 400; line-height: 20px; letter-spacing: 0.25px; color: var(--text-700); white-space: nowrap; }
    .nav-chevron { width: 16px; height: 16px; display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
    .nav-chevron svg { width: 10px; height: 6px; fill: none; stroke: var(--text-700); stroke-width: 1.5; }
    .header-actions { display: flex; align-items: center; gap: 16px; }
    .btn-icon { width: 36px; height: 36px; border-radius: 12px; display: flex; align-items: center; justify-content: center; cursor: pointer; background: transparent; border: none; padding: 0; }
    .btn-icon svg { width: 20px; height: 20px; stroke: var(--text-900); fill: none; stroke-width: 1.5; }
    .btn-login { height: 40px; padding: 0 10px; border-radius: 16px; border: none; background: transparent; font-family: 'Lato', sans-serif; font-size: 14px; font-weight: 600; line-height: 20px; letter-spacing: 0.25px; color: var(--text-900); cursor: pointer; box-shadow: var(--shadow-btn); white-space: nowrap; }
    .btn-list { height: 40px; padding: 0 12px; border-radius: 12px; border: 1px solid var(--text-100); background: var(--white); font-family: 'Lato', sans-serif; font-size: 14px; font-weight: 600; line-height: 20px; letter-spacing: 0.25px; color: var(--text-900); cursor: pointer; box-shadow: var(--shadow-btn); white-space: nowrap; }

    /* ─── BREADCRUMB ─────────────────────────────────── */
    .breadcrumb {
      padding: 18px 0;
    }
    .breadcrumb .inner {
      display: flex;
      align-items: center;
      gap: 8px;
    }
    .breadcrumb a, .breadcrumb span {
      font-size: 13px;
      font-weight: 400;
      color: var(--text-500);
      text-decoration: none;
    }
    .breadcrumb a:hover { color: var(--text-700); }
    .breadcrumb .current { color: var(--text-900); font-weight: 600; }
    .breadcrumb .sep { color: var(--text-200); }

    /* ─── LAYOUT ─────────────────────────────────────── */
    .detail-body {
      padding: 0 0 48px;
    }
    .detail-body .inner {
      display: grid;
      grid-template-columns: 1fr 360px;
      gap: 32px;
      align-items: start;
    }

    /* ─── GALLERY ────────────────────────────────────── */
    .gallery {
      display: grid;
      grid-template-columns: 2fr 1fr;
      grid-template-rows: 190px 190px;
      gap: 8px;
      border-radius: 16px;
      overflow: hidden;
      margin-bottom: 24px;
    }
    .gallery-main {
      grid-row: span 2;
      overflow: hidden;
      border-radius: 12px 0 0 12px;
    }
    .gallery-main img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
    }
    .gallery-thumb {
      overflow: hidden;
      position: relative;
      border-radius: 0;
    }
    .gallery-thumb:first-of-type { border-radius: 0 12px 0 0; }
    .gallery-thumb:last-of-type { border-radius: 0 0 12px 0; }
    .gallery-thumb img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
    }
    .gallery-more-overlay {
      position: absolute;
      inset: 0;
      background: rgba(15,23,43,0.5);
      display: flex;
      align-items: center;
      justify-content: center;
      color: var(--white);
      font-size: 16px;
      font-weight: 700;
      cursor: pointer;
    }

    /* ─── TITLE ROW ──────────────────────────────────── */
    .title-block { display: flex; flex-direction: column; gap: 10px; margin-bottom: 20px; }
    .title-row {
      display: flex;
      align-items: flex-start;
      justify-content: space-between;
      gap: 16px;
    }
    .wh-name {
      font-size: 28px;
      font-weight: 700;
      line-height: 34px;
      color: var(--text-900);
    }
    .title-actions { display: flex; gap: 8px; flex-direction: column; align-items: flex-end; }
    .btn-outline-sm {
      height: 36px;
      padding: 0 14px;
      border-radius: 10px;
      border: 1px solid var(--text-100);
      background: var(--white);
      font-family: 'Lato', sans-serif;
      font-size: 13px;
      font-weight: 600;
      color: var(--text-900);
      cursor: pointer;
      display: inline-flex;
      align-items: center;
      gap: 6px;
      white-space: nowrap;
    }
    .btn-outline-sm svg { width: 14px; height: 14px; stroke: var(--text-900); fill: none; stroke-width: 1.5; }
    .save-share-row { display: flex; gap: 8px; }

    .location-row {
      display: flex;
      align-items: center;
      gap: 6px;
    }
    .location-row svg { width: 16px; height: 16px; stroke: var(--secondary-500); fill: none; stroke-width: 1.5; }
    .location-row span { font-size: 14px; color: var(--text-700); }

    .rating-row { display: flex; align-items: center; gap: 4px; }
    .rating-row .star { color: var(--star); font-size: 14px; }
    .rating-row .score { font-size: 13px; font-weight: 600; color: var(--text-900); }
    .rating-row .reviews { font-size: 13px; color: var(--text-500); }

    /* ─── STATS BAR ──────────────────────────────────── */
    .stats-bar {
      background: var(--white);
      border: 1px solid var(--text-100);
      border-radius: 12px;
      padding: 16px;
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 16px;
      margin-bottom: 16px;
    }
    .stat {
      display: flex;
      flex-direction: column;
      gap: 2px;
      padding: 0 12px;
      border-right: 1px solid var(--text-100);
    }
    .stat:last-child { border-right: none; }
    .stat-value {
      font-size: 15px;
      font-weight: 700;
      color: var(--text-900);
      line-height: 22px;
    }
    .stat-label {
      font-size: 12px;
      color: var(--text-500);
      line-height: 16px;
    }

    /* ─── AVAILABILITY BAR ───────────────────────────── */
    .availability-bar {
      background: #F0FAF8;
      border: 1px solid #D4EDE7;
      border-radius: 12px;
      padding: 14px 16px;
      margin-bottom: 20px;
      display: flex;
      flex-direction: column;
      gap: 8px;
    }
    .availability-top {
      display: flex;
      align-items: center;
      justify-content: space-between;
    }
    .availability-label {
      display: flex;
      align-items: center;
      gap: 6px;
      font-size: 14px;
      font-weight: 600;
      color: var(--text-900);
    }
    .availability-label svg { width: 14px; height: 14px; fill: var(--secondary-500); }
    .availability-count {
      font-size: 13px;
      color: var(--text-700);
    }
    .availability-track {
      height: 6px;
      background: #D4EDE7;
      border-radius: 4px;
      overflow: hidden;
    }
    .availability-fill {
      height: 100%;
      background: var(--secondary-500);
      width: 5.8%;
      border-radius: 4px;
    }

    /* ─── DESCRIPTION ────────────────────────────────── */
    .description {
      font-size: 14px;
      line-height: 22px;
      color: var(--text-700);
      margin-bottom: 24px;
    }

    /* ─── TABS ───────────────────────────────────────── */
    .tabs {
      display: flex;
      gap: 24px;
      border-bottom: 1px solid var(--text-100);
      margin-bottom: 24px;
    }
    .tab {
      padding: 10px 0;
      font-size: 14px;
      font-weight: 400;
      color: var(--text-500);
      background: transparent;
      border: none;
      border-bottom: 2px solid transparent;
      cursor: pointer;
      font-family: 'Lato', sans-serif;
    }
    .tab.active {
      color: var(--text-900);
      font-weight: 600;
      border-bottom-color: var(--secondary-500);
    }

    /* ─── SERVICES SECTION ───────────────────────────── */
    .services-section { margin-bottom: 32px; }
    .section-title {
      font-size: 16px;
      font-weight: 700;
      color: var(--text-900);
      margin-bottom: 12px;
    }
    .services-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 12px;
    }
    .service-table {
      border: 1px solid var(--text-100);
      border-radius: 12px;
      overflow: hidden;
    }
    .service-table-head {
      background: var(--bg-50);
      padding: 12px 16px;
      font-size: 13px;
      font-weight: 700;
      color: var(--text-900);
      border-bottom: 1px solid var(--text-100);
    }
    .service-row {
      display: flex;
      justify-content: space-between;
      padding: 12px 16px;
      font-size: 14px;
      color: var(--text-700);
      border-bottom: 1px solid var(--text-100);
    }
    .service-row:last-child { border-bottom: none; }
    .service-row .rate { font-weight: 600; color: var(--text-900); }
    .service-row.na { color: var(--text-500); }
    .service-row.na .rate { color: var(--text-500); font-weight: 400; }

    .services-footnote {
      font-size: 12px;
      color: var(--text-500);
      margin-top: 12px;
    }

    /* ─── NEARBY ─────────────────────────────────────── */
    .nearby-section { margin-top: 12px; }
    .nearby-header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      margin-bottom: 14px;
    }
    .nearby-title { font-size: 16px; font-weight: 700; color: var(--text-900); }
    .view-all {
      font-size: 13px;
      color: var(--secondary-600);
      font-weight: 600;
      display: flex;
      align-items: center;
      gap: 4px;
      text-decoration: none;
    }
    .view-all svg { width: 12px; height: 12px; stroke: var(--secondary-600); fill: none; stroke-width: 2; }

    .nearby-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 16px;
    }
    .mini-card {
      background: var(--white);
      border-radius: 14px;
      box-shadow: var(--shadow-card);
      overflow: hidden;
      display: flex;
      flex-direction: column;
    }
    .mini-card-image {
      height: 140px;
      position: relative;
      overflow: hidden;
    }
    .mini-card-image img {
      width: 100%;
      height: 100%;
      object-fit: cover;
    }
    .mini-card-badge {
      position: absolute;
      top: 10px;
      left: 10px;
      height: 22px;
      padding: 0 8px;
      border-radius: 6px;
      display: flex;
      align-items: center;
      gap: 4px;
      font-size: 10px;
      font-weight: 600;
      background: rgba(255,255,255,0.92);
    }
    .mini-card-badge.instant { color: var(--secondary-500); }
    .mini-card-badge.standard { color: var(--text-700); }
    .mini-card-badge svg { width: 10px; height: 10px; }
    .mini-card-badge.instant svg { fill: var(--secondary-500); stroke: none; }
    .mini-card-badge.standard svg { stroke: var(--text-700); fill: none; stroke-width: 1.5; }

    .mini-card-body { padding: 14px; display: flex; flex-direction: column; gap: 6px; }
    .mini-card-row { display: flex; align-items: center; justify-content: space-between; }
    .mini-card-name { font-size: 15px; font-weight: 700; color: var(--text-900); }
    .mini-card-rating { display: flex; align-items: center; gap: 3px; font-size: 12px; }
    .mini-card-rating .star { color: var(--star); }
    .mini-card-rating .score { font-weight: 600; color: var(--text-900); }
    .mini-card-rating .reviews { color: var(--text-500); }
    .mini-card-location { display: flex; align-items: center; gap: 4px; font-size: 12px; color: var(--text-500); }
    .mini-card-location svg { width: 12px; height: 12px; stroke: var(--secondary-500); fill: none; stroke-width: 1.5; }
    .mini-card-price { font-size: 15px; font-weight: 700; color: var(--text-900); margin-top: 2px; }
    .mini-card-price .unit { font-size: 11px; font-weight: 400; color: var(--text-500); }
    .mini-card-actions { display: flex; gap: 6px; margin-top: 8px; }
    .mini-btn-compare, .mini-btn-view {
      flex: 1;
      height: 32px;
      border-radius: 8px;
      font-family: 'Lato', sans-serif;
      font-size: 12px;
      font-weight: 600;
      cursor: pointer;
    }
    .mini-btn-compare { background: var(--white); border: 1px solid var(--text-100); color: var(--text-900); }
    .mini-btn-view { border: none; background: linear-gradient(156deg, var(--secondary-500) 0%, var(--secondary-600) 100%); color: var(--white); }

    /* ─── STICKY ESTIMATE CARD ───────────────────────── */
    .estimate-card {
      background: var(--white);
      border: 1px solid var(--text-100);
      border-radius: 16px;
      padding: 20px;
      position: sticky;
      top: 80px;
      display: flex;
      flex-direction: column;
      gap: 16px;
    }
    .estimate-price-row {
      display: flex;
      align-items: baseline;
      justify-content: space-between;
      gap: 8px;
      flex-wrap: wrap;
    }
    .estimate-price {
      font-size: 28px;
      font-weight: 700;
      color: var(--text-900);
      line-height: 32px;
    }
    .estimate-price .unit {
      font-size: 14px;
      font-weight: 400;
      color: var(--text-500);
    }

    .estimate-meta {
      display: flex;
      align-items: center;
      justify-content: space-between;
      font-size: 12px;
      color: var(--text-500);
    }
    .estimate-meta .total {
      font-weight: 700;
      color: var(--text-900);
    }

    .estimate-inputs {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 8px;
    }
    .input-field {
      display: flex;
      flex-direction: column;
      gap: 4px;
      border: 1px solid var(--text-100);
      border-radius: 10px;
      padding: 8px 12px;
    }
    .input-field label {
      font-size: 11px;
      color: var(--text-500);
      line-height: 14px;
    }
    .input-field .value-row {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 4px;
    }
    .input-field .value-row span {
      font-size: 14px;
      font-weight: 600;
      color: var(--text-900);
    }
    .input-field .value-row svg { width: 14px; height: 14px; stroke: var(--text-700); fill: none; stroke-width: 1.5; }

    /* Storage options */
    .storage-options { display: flex; flex-direction: column; gap: 8px; }
    .storage-options-label { font-size: 13px; font-weight: 600; color: var(--text-900); margin-bottom: 2px; }
    .storage-option {
      border: 1px solid var(--text-100);
      border-radius: 12px;
      padding: 12px 14px;
      display: flex;
      align-items: flex-start;
      gap: 10px;
      cursor: pointer;
    }
    .storage-option.selected {
      border-color: var(--secondary-500);
      background: #F0FAF8;
    }
    .radio {
      width: 18px;
      height: 18px;
      border-radius: 50%;
      border: 1.5px solid var(--text-200);
      flex-shrink: 0;
      margin-top: 2px;
      display: flex;
      align-items: center;
      justify-content: center;
    }
    .storage-option.selected .radio {
      border-color: var(--secondary-500);
    }
    .storage-option.selected .radio::after {
      content: '';
      width: 8px;
      height: 8px;
      border-radius: 50%;
      background: var(--secondary-500);
    }
    .option-body { flex: 1; display: flex; flex-direction: column; gap: 2px; }
    .option-row {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 8px;
    }
    .option-name { font-size: 14px; font-weight: 700; color: var(--text-900); display: flex; align-items: center; gap: 6px; }
    .option-chip {
      background: rgba(64,188,170,0.12);
      color: var(--secondary-600);
      font-size: 11px;
      font-weight: 600;
      padding: 2px 6px;
      border-radius: 6px;
      display: inline-flex;
      align-items: center;
      gap: 3px;
    }
    .option-chip svg { width: 10px; height: 10px; fill: var(--secondary-500); }
    .option-price {
      font-size: 13px;
      font-weight: 700;
      color: var(--text-900);
    }
    .option-sub {
      font-size: 12px;
      color: var(--text-500);
    }

    /* Form inputs */
    .form-group { display: flex; flex-direction: column; gap: 4px; }
    .form-group label { font-size: 12px; font-weight: 600; color: var(--text-900); }
    .form-group input {
      height: 40px;
      border: 1px solid var(--text-100);
      border-radius: 10px;
      padding: 0 12px;
      font-family: 'Lato', sans-serif;
      font-size: 14px;
      color: var(--text-900);
      outline: none;
      width: 100%;
    }
    .form-group input:focus { border-color: var(--secondary-500); }
    .form-group input::placeholder { color: var(--text-500); }

    .btn-estimate {
      display: flex;
      align-items: center;
      justify-content: center;
      height: 44px;
      border-radius: 12px;
      border: none;
      background: linear-gradient(156deg, var(--secondary-500) 0%, var(--secondary-600) 100%);
      color: var(--white);
      font-family: 'Lato', sans-serif;
      font-size: 14px;
      font-weight: 700;
      cursor: pointer;
      text-decoration: none;
    }
    .estimate-caption {
      font-size: 11px;
      color: var(--text-500);
      line-height: 16px;
      text-align: center;
    }

  /* ─── FOOTER ──────────────────────────────── */
  .footer .inner { max-width: 1280px; margin: 0 auto; padding: 0 80px; }
  .footer { background: var(--text-900); padding: 80px 0 32px; color: rgba(255,255,255,0.7); }
  .footer-grid { display: grid; grid-template-columns: 1.4fr 1fr 1.2fr 1.2fr 1fr 1fr; gap: 48px; margin-bottom: 64px; }
  .footer-brand { display: flex; flex-direction: column; gap: 20px; }
  .footer-logo { display: flex; align-items: center; gap: 8px; font-size: 28px; font-weight: 700; color: #fff; letter-spacing: -0.5px; }
  .footer-tagline { font-size: 16px; color: rgba(255,255,255,0.55); line-height: 1.5; max-width: 260px; }
  .footer-cities { display: flex; flex-wrap: wrap; gap: 8px; max-width: 280px; }
  .footer-city-chip { display: inline-flex; align-items: center; padding: 8px 14px; background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.12); border-radius: 999px; font-size: 14px; color: rgba(255,255,255,0.85); text-decoration: none; transition: border-color .12s, background .12s, color .12s; }
  .footer-city-chip:hover { border-color: var(--secondary-500); background: rgba(64,188,170,0.1); color: #fff; }
  .footer-col-title { font-size: 12px; font-weight: 700; letter-spacing: 1.5px; text-transform: uppercase; color: rgba(255,255,255,0.45); margin-bottom: 24px; }
  .footer-link { display: block; font-size: 16px; color: rgba(255,255,255,0.75); padding: 8px 0; text-decoration: none; transition: color .12s; }
  .footer-link:hover { color: var(--secondary-500); }
  .footer-divider { border: 0; border-top: 1px solid rgba(255,255,255,0.08); margin: 0; }
  .footer-browse { padding: 40px 0; }
  .footer-browse-title { font-size: 12px; font-weight: 700; letter-spacing: 1.5px; text-transform: uppercase; color: rgba(255,255,255,0.45); margin-bottom: 20px; }
  .footer-browse-grid { display: grid; grid-template-columns: repeat(5, 1fr); gap: 16px; }
  .footer-select { appearance: none; -webkit-appearance: none; width: 100%; height: 52px; padding: 0 44px 0 20px; background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.14); border-radius: 12px; font-family: 'Lato', sans-serif; font-size: 16px; color: #fff; cursor: pointer; background-image: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' width='12' height='8' viewBox='0 0 12 8' fill='none'><path d='M1 1.5L6 6.5L11 1.5' stroke='rgba(255,255,255,0.6)' stroke-width='1.5' stroke-linecap='round' stroke-linejoin='round'/></svg>"); background-repeat: no-repeat; background-position: right 20px center; transition: border-color .12s, background .12s; }
  .footer-select option { background: var(--text-900); color: #fff; }
  .footer-select:hover { border-color: var(--secondary-500); }
  .footer-select:focus { outline: none; border-color: var(--secondary-500); }
