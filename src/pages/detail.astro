<script is:inline>
(function(){
  const params = new URLSearchParams(location.search);
  const id = params.get("id");
  const sizeInput = parseInt(params.get("size"), 10) || 100;
  const sizeUnit = params.get("unit") || "Sqft";
  const period = params.get("period") || "1 Month";
  const goodsIntent = params.get("goodsIntent") || "General Cargo";
  const months = periodToInt(period);

  let w = WAREHOUSES.find(x => x.id === id);
  if (!w) w = WAREHOUSES[0];

  const ctx = { sizeInput, sizeUnit, period, goodsIntent, warehouseTypeFilters: [] };

  /* ----- Title meta ----- */
  document.title = `${w.id} in ${w.area} — Cargoz`;

  /* ----- Breadcrumb ----- */
  const crumbs = document.querySelectorAll(".breadcrumb a, .breadcrumb .current");
  if (crumbs.length >= 4) {
    crumbs[1].textContent = `Warehouses in ${w.emirate}`;
    crumbs[1].href = `listings.html?city=${encodeURIComponent(w.emirate)}`;
    crumbs[2].textContent = w.area;
    crumbs[3].textContent = `${w.id} in ${w.area}`;
  }

  /* ----- Gallery ----- */
  const galleryEl = document.querySelector(".gallery");
  if (galleryEl) galleryEl.style.gridTemplateRows = "240px 240px";
  const imgs = (w.images || []).map(i => i.url);
  if (imgs.length) {
    const main = document.querySelector(".gallery-main img");
    const mainCell = document.querySelector(".gallery-main");
    if (main) { main.src = imgs[0]; main.alt = w.id; }
    const thumbs = document.querySelectorAll(".gallery-thumb");
    if (imgs.length === 1 && mainCell) {
      mainCell.style.gridColumn = "1 / span 2";
      mainCell.style.gridRow = "1 / span 2";
      mainCell.style.borderRadius = "12px";
      thumbs.forEach(t => { t.style.display = "none"; });
    } else if (imgs.length === 2) {
      const t0 = thumbs[0];
      if (t0) {
        const tImg = t0.querySelector("img");
        if (tImg) { tImg.src = imgs[1]; tImg.alt = w.id; }
        t0.style.display = "";
        t0.style.gridRow = "1 / span 2";
        t0.style.borderRadius = "0 12px 12px 0";
      }
      if (thumbs[1]) thumbs[1].style.display = "none";
    } else {
      thumbs.forEach((t, i) => {
        const tImg = t.querySelector("img");
        if (i + 1 < imgs.length) {
          if (tImg) { tImg.src = imgs[i + 1]; tImg.alt = w.id; }
          t.style.display = "";
        } else {
          t.style.display = "none";
        }
      });
    }
    const moreOverlay = document.querySelector(".gallery-more-overlay");
    if (moreOverlay) {
      const remaining = imgs.length - thumbs.length - 1;
      if (remaining > 0) {
        moreOverlay.textContent = `+${remaining} more`;
        moreOverlay.style.display = "";
      } else {
        moreOverlay.style.display = "none";
      }
    }
    document.querySelectorAll(".gallery-thumb img").forEach((tImg, i) => {
      tImg.style.cursor = "pointer";
      tImg.onclick = () => {
        const main = document.querySelector(".gallery-main img");
        if (!main) return;
        const tmp = main.src;
        main.src = tImg.src;
        tImg.src = tmp;
      };
    });
  }

  /* ----- Title block ----- */
  document.querySelector(".wh-name").textContent = w.id;
  document.querySelector(".location-row span").textContent = `${w.area}, ${w.emirate}`;
  document.querySelector(".rating-row .score").textContent = w.rating.toFixed(1);
  document.querySelector(".rating-row .reviews").textContent = `(${w.reviews} reviews)`;

  /* ----- Stats bar ----- */
  const price = getUOMPrice(w, ctx);
  const validPrice = price !== Infinity ? price : (w.rateCard[0] ? w.rateCard[0].price : 0);
  const unitWord = sizeUnit === "Sqft" ? "sqft" : sizeUnit;
  const stats = document.querySelectorAll(".stats-bar .stat");
  if (stats.length >= 4) {
    stats[0].querySelector(".stat-value").textContent = "AED " + validPrice.toLocaleString("en-AE", {minimumFractionDigits: 2, maximumFractionDigits: 2});
    stats[0].querySelector(".stat-label").textContent = `/${unitWord}/mo from`;
    const totalAvail = (w.instantAvailability && w.instantAvailability.fixedArea) ? w.instantAvailability.fixedArea : (w.rateCard[0] && w.rateCard[0].min ? w.rateCard[0].min * 80 : 5000);
    stats[1].querySelector(".stat-value").textContent = totalAvail.toLocaleString("en-AE") + " " + unitWord;
    stats[1].querySelector(".stat-label").textContent = "Available Space";
    const zones = getTempZones(w);
    stats[2].querySelector(".stat-value").textContent = zones[0] || "Mixed";
    stats[2].querySelector(".stat-label").textContent = "Temperature";
    stats[3].querySelector(".stat-value").textContent = w.accessHours || "24/7";
    stats[3].querySelector(".stat-label").textContent = "Operation Access";
  }

  /* ----- Availability bar ----- */
  const fa = (w.instantAvailability && w.instantAvailability.fixedArea) || 0;
  const totalForBar = Math.max(fa, 1) * 8;
  const pct = Math.max(8, Math.min(95, Math.round((fa / totalForBar) * 100)));
  const availLabel = document.querySelector(".availability-count");
  const availFill = document.querySelector(".availability-fill");
  const availBar = document.querySelector(".availability-bar");
  if (fa > 0) {
    if (availLabel) availLabel.textContent = `${fa.toLocaleString("en-AE")} ${unitWord} of ${totalForBar.toLocaleString("en-AE")} ${unitWord} available`;
    if (availFill) availFill.style.width = pct + "%";
    if (availBar) availBar.style.display = "";
  } else if (availBar) {
    availBar.style.display = "none";
  }

  /* ----- Description ----- */
  const desc = document.querySelector(".description");
  if (desc) {
    const zones = getTempZones(w).join(" / ");
    const cargos = [...new Set(w.rateCard.map(r => r.cargo))].join(", ");
    desc.textContent = `${w.id} offers flexible storage in ${w.area}, ${w.emirate}. The facility handles ${cargos} in ${zones || "various"} zones, with rates starting from AED ${validPrice.toFixed(2)}/${unitWord} per month. Open ${w.accessHours || "24/7"} with handling services available.`;
  }

  /* ----- Tabs + Facilities panel ----- */
  const ratesSection = document.querySelector(".services-section");

  // Build Facilities panel
  const SEC_KEYS = ["CCTV","Fire alarm","Access control","24/7 Security","Smoke detector","Sprinkler","Guard"];
  const isSecurity = (f) => SEC_KEYS.some(k => f.toLowerCase().includes(k.toLowerCase()));
  const allFacilities = w.facilities || [];
  const securityItems = allFacilities.filter(isSecurity);
  if (w.accessHours && w.accessHours.includes("24/7") && !securityItems.some(s => /24\/7/i.test(s))) {
    securityItems.push("24/7 Access");
  }
  const equipItems = allFacilities.filter(f => !isSecurity(f));
  const tempZonesArr = getTempZones(w);
  const totalArea = (w.instantAvailability && w.instantAvailability.fixedArea) || 0;

  const facWrap = "background:var(--white);border-radius:16px;padding:0;display:none;flex-direction:column;gap:32px;";
  const facTitle = "font-family:'Lato',sans-serif;font-size:20px;font-weight:700;color:var(--text-900);margin:0 0 16px;line-height:28px;";
  const specCard = "border:1px solid var(--text-100);border-radius:12px;padding:0;display:grid;grid-template-columns:1fr 1fr;overflow:hidden;";
  const specCell = "padding:16px 20px;border-right:1px solid var(--text-100);border-bottom:1px solid var(--text-100);";
  const specCellLast = "padding:16px 20px;border-bottom:1px solid var(--text-100);";
  const specLbl = "font-family:'Lato',sans-serif;font-size:13px;font-weight:400;color:var(--text-500);line-height:18px;margin-bottom:6px;";
  const specVal = "font-family:'Lato',sans-serif;font-size:16px;font-weight:700;color:var(--text-900);line-height:22px;";
  const pillRow = "display:flex;flex-wrap:wrap;gap:10px;";
  const pillEquip = "display:inline-flex;align-items:center;height:36px;padding:0 16px;border:1px solid var(--text-100);border-radius:999px;background:var(--white);font-family:'Lato',sans-serif;font-size:14px;font-weight:500;color:var(--text-700);";
  const pillSec = "display:inline-flex;align-items:center;gap:6px;height:36px;padding:0 14px;border-radius:999px;background:#F2FFFE;color:var(--secondary-600);font-family:'Lato',sans-serif;font-size:14px;font-weight:600;";
  const secDot = "width:6px;height:6px;border-radius:50%;background:var(--secondary-500);";

  const specRows = [
    { lbl: "Total area", val: totalArea ? totalArea.toLocaleString("en-AE") + " SQFT" : "On request" },
    { lbl: "Clear height", val: "10m" },
    { lbl: "Temperature", val: tempZonesArr.length ? tempZonesArr.join(" / ") : "Ambient" },
    { lbl: "Access hours", val: w.accessHours || "24/7" }
  ];
  let specHTML = "";
  specRows.forEach((r, i) => {
    const last = (i % 2 === 1);
    const bottomRow = i >= specRows.length - 2;
    let style = last ? specCellLast : specCell;
    if (bottomRow) style = style.replace("border-bottom:1px solid var(--text-100);", "");
    specHTML += `<div style="${style}"><div style="${specLbl}">${r.lbl}</div><div style="${specVal}">${r.val}</div></div>`;
  });

  const equipHTML = equipItems.length
    ? `<div><h4 style="${facTitle}">Facilities &amp; equipment</h4><div style="${pillRow}">${equipItems.map(f => `<span style="${pillEquip}">${f}</span>`).join("")}</div></div>`
    : "";
  const secHTML = securityItems.length
    ? `<div><h4 style="${facTitle}">Security</h4><div style="${pillRow}">${securityItems.map(f => `<span style="${pillSec}"><span style="${secDot}"></span>${f}</span>`).join("")}</div></div>`
    : "";

  // Trust & compliance — same tokens as rates service-table
  const TRUST_ITEMS = ["Water Sprinkler","Fire Alarm","CCTV","Electricity","Toilet","Smoke Detector","24/7 Access"];
  const has = (label) => {
    const l = label.toLowerCase();
    if (l === "24/7 access") return (w.accessHours || "").includes("24/7");
    if (l === "water sprinkler") return allFacilities.some(f => /sprinkler/i.test(f));
    if (l === "fire alarm") return allFacilities.some(f => /fire alarm/i.test(f));
    if (l === "cctv") return allFacilities.some(f => /cctv/i.test(f));
    if (l === "electricity") return true;
    if (l === "toilet") return allFacilities.some(f => /washroom|toilet/i.test(f));
    if (l === "smoke detector") return allFacilities.some(f => /smoke/i.test(f));
    return false;
  };
  const trustHTML = `<div><h4 style="${facTitle}">Trust &amp; compliance</h4>
    <div class="service-table">
      <div class="service-table-head">Compliance &amp; safety</div>
      ${TRUST_ITEMS.map(item => {
        const ok = has(item);
        return `<div class="service-row${ok ? "" : " na"}"><span>${item}</span><span class="rate">${ok ? "Included" : "N/A"}</span></div>`;
      }).join("")}
    </div></div>`;

  const facSection = document.createElement("div");
  facSection.className = "facilities-section";
  facSection.style.cssText = facWrap;
  facSection.innerHTML = `
    <div><h4 style="${facTitle}">Specifications</h4><div style="${specCard}">${specHTML}</div></div>
    ${equipHTML}
    ${secHTML}
    ${trustHTML}
  `;
  if (ratesSection && ratesSection.parentNode) {
    ratesSection.parentNode.insertBefore(facSection, ratesSection.nextSibling);
  }

  // Reviews panel — Cargoz UI tokens (bordered white card, --text-100, Lato)
  const SAMPLE_REVIEWS = [
    { name: "Ahmed R.",     company: "Al Noor Logistics", rating: 5, text: "Easy move-in, team was responsive. Unit was clean and secure.",                  ago: "2 weeks ago" },
    { name: "Priya S.",     company: "UAE Imports Co.",   rating: 4, text: "Good value for the location. Minor wait for loading dock on peak days.",         ago: "1 month ago" },
    { name: "Mohammed K.",  company: "Gulf Freight",      rating: 5, text: "Reliable partner. Rates honoured as quoted.",                                    ago: "2 months ago" }
  ];

  const revCard = "border:1px solid var(--text-100);border-radius:12px;padding:20px 24px;background:var(--white);";
  const revHead = "display:flex;align-items:flex-start;justify-content:space-between;gap:16px;";
  const revIdent = "font-family:'Lato',sans-serif;font-size:15px;line-height:22px;";
  const revName = "font-weight:700;color:var(--text-900);";
  const revCo = "font-weight:400;color:var(--text-500);";
  const revDate = "font-family:'Lato',sans-serif;font-size:13px;color:var(--text-500);white-space:nowrap;flex-shrink:0;";
  const revStars = "display:flex;gap:2px;color:var(--star);font-size:14px;line-height:1;margin:8px 0 12px;";
  const revText = "font-family:'Lato',sans-serif;font-size:14px;line-height:22px;color:var(--text-700);margin:0;";
  const revListWrap = "display:flex;flex-direction:column;gap:12px;";

  const starHTML = (rating) => {
    let out = "";
    for (let i = 1; i <= 5; i++) {
      out += i <= rating ? "★" : `<span style="color:var(--text-100);">★</span>`;
    }
    return out;
  };
  const reviewsListHTML = SAMPLE_REVIEWS.map(r => `
    <div style="${revCard}">
      <div style="${revHead}">
        <div style="${revIdent}"><span style="${revName}">${r.name}</span> <span style="${revCo}">· ${r.company}</span></div>
        <div style="${revDate}">${r.ago}</div>
      </div>
      <div style="${revStars}">${starHTML(r.rating)}</div>
      <p style="${revText}">${r.text}</p>
    </div>
  `).join("");

  const revSection = document.createElement("div");
  revSection.className = "reviews-section";
  revSection.style.cssText = "display:none;flex-direction:column;gap:24px;";
  revSection.innerHTML = `
    <div>
      <h4 style="${facTitle}">Recent reviews</h4>
      <div style="${revListWrap}">${reviewsListHTML}</div>
    </div>
  `;
  if (ratesSection && ratesSection.parentNode) {
    ratesSection.parentNode.insertBefore(revSection, ratesSection.nextSibling);
  }

  // FAQ panel — Cargoz UI tokens, always expanded (no accordion)
  const SAMPLE_FAQS = [
    { q: "How quickly can I move in?", a: `Most warehouses on Cargoz offer 24-hour or 3–5 day move-in. ${w.id} is currently showing fast-track availability — final confirmation happens once your enquiry is verified.` },
    { q: "Is there a minimum contract or lock-in?", a: "No yearly lock-in. You can rent from 1 month onwards, with weekly, monthly, or yearly billing. Notice period applies as per the terms in your final estimate." },
    { q: "What's included in the price?", a: "The headline rate covers the storage space itself. Handling services (palletization, forklift, labour, shrink wrapping, labelling) are billed separately at the rates listed in the Rates & Handling Services tab." },
    { q: "Do you handle insurance?", a: "Insurance coverage is not provided by Cargoz. We recommend customers arrange their own cargo insurance. Our team can introduce trusted insurers on request." },
    { q: "Can I visit the warehouse before booking?", a: "Yes — site visits are encouraged. Once you submit an enquiry, our advisor coordinates a visit at a time that suits you, usually within 24 working hours." },
    { q: "How do I pay?", a: "Bank transfer, cheque, or card. A refundable security deposit equal to one month's charges is required to confirm the booking." }
  ];

  const faqCard = "border:1px solid var(--text-100);border-radius:12px;padding:20px 24px;background:var(--white);";
  const faqQ = "font-family:'Lato',sans-serif;font-size:15px;font-weight:700;line-height:22px;color:var(--text-900);margin:0 0 8px;";
  const faqA = "font-family:'Lato',sans-serif;font-size:14px;font-weight:400;line-height:22px;color:var(--text-700);margin:0;";
  const faqListWrap = "display:flex;flex-direction:column;gap:12px;";

  const faqsListHTML = SAMPLE_FAQS.map(f => `
    <div style="${faqCard}">
      <h5 style="${faqQ}">${f.q}</h5>
      <p style="${faqA}">${f.a}</p>
    </div>
  `).join("");

  const faqSection = document.createElement("div");
  faqSection.className = "faqs-section";
  faqSection.style.cssText = "display:none;flex-direction:column;gap:24px;";
  faqSection.innerHTML = `
    <div>
      <h4 style="${facTitle}">Frequently asked questions</h4>
      <div style="${faqListWrap}">${faqsListHTML}</div>
    </div>
  `;
  if (ratesSection && ratesSection.parentNode) {
    ratesSection.parentNode.insertBefore(faqSection, ratesSection.nextSibling);
  }

  document.querySelectorAll(".tabs .tab").forEach(t => {
    t.onclick = () => {
      document.querySelectorAll(".tabs .tab").forEach(x => x.classList.remove("active"));
      t.classList.add("active");
      const label = t.textContent.trim();
      if (ratesSection) ratesSection.style.display = "none";
      facSection.style.display = "none";
      revSection.style.display = "none";
      faqSection.style.display = "none";
      if (label === "Facilities") facSection.style.display = "flex";
      else if (label === "Reviews") revSection.style.display = "flex";
      else if (label === "FAQs") faqSection.style.display = "flex";
      else if (ratesSection) ratesSection.style.display = "";
    };
  });

  /* ----- Estimate card — steppers for Period & Size ----- */
  let curSize = sizeInput;
  let curMonths = months;
  const sizeLim = SIZE_LIMITS[sizeUnit] || { min: 50, max: 5000 };
  const sizeStep = sizeUnit === "Sqft" ? 50 : 5;

  const stepBtn = "width:24px;height:24px;border-radius:6px;border:1px solid var(--text-100);background:var(--white);display:flex;align-items:center;justify-content:center;cursor:pointer;flex-shrink:0;padding:0;";
  const stepSvg = "width:12px;height:12px;stroke:var(--text-700);fill:none;stroke-width:2;";
  const minusSvg = `<svg viewBox="0 0 12 2" style="${stepSvg}"><line x1="1" y1="1" x2="11" y2="1"/></svg>`;
  const plusSvg = `<svg viewBox="0 0 12 12" style="${stepSvg}"><line x1="6" y1="1" x2="6" y2="11"/><line x1="1" y1="6" x2="11" y2="6"/></svg>`;
  const stepperWrap = "display:flex;align-items:center;gap:8px;border:1px solid var(--text-100);border-radius:10px;padding:6px 10px;background:var(--white);";
  const valStyle = "flex:1;text-align:center;font-size:14px;font-weight:600;line-height:20px;color:var(--text-900);";
  const unitStyle = "font-size:12px;font-weight:400;color:var(--text-500);margin-left:4px;";
  const sectionLabel = "display:block;font-size:13px;font-weight:700;line-height:18px;color:var(--text-900);margin-bottom:10px;";

  const inputsWrap = document.querySelector(".estimate-inputs");
  if (inputsWrap) {
    inputsWrap.style.display = "grid";
    inputsWrap.style.gridTemplateColumns = "1fr 1fr";
    inputsWrap.style.gap = "12px";
    inputsWrap.innerHTML = `
      <div>
        <span style="${sectionLabel}">Period</span>
        <div style="${stepperWrap}">
          <button id="d-dur-minus" type="button" style="${stepBtn}">${minusSvg}</button>
          <span style="${valStyle}"><span id="d-dur-val">${curMonths}</span><span id="d-dur-unit" style="${unitStyle}">${curMonths === 1 ? 'Month' : 'Months'}</span></span>
          <button id="d-dur-plus" type="button" style="${stepBtn}">${plusSvg}</button>
        </div>
      </div>
      <div>
        <span style="${sectionLabel}">Size</span>
        <div style="${stepperWrap}">
          <button id="d-sz-minus" type="button" style="${stepBtn}">${minusSvg}</button>
          <span style="${valStyle}"><span id="d-sz-val">${curSize.toLocaleString('en-AE')}</span><span style="${unitStyle}">${unitWord}</span></span>
          <button id="d-sz-plus" type="button" style="${stepBtn}">${plusSvg}</button>
        </div>
      </div>`;
  }

  function recompute() {
    const estTotal = Math.max(validPrice * curSize, (w.rateCard[0] || {}).min || 0);
    const ep = document.querySelector(".estimate-price");
    if (ep) ep.innerHTML = `AED ${Math.round(estTotal).toLocaleString("en-AE")} <span class="unit">/ month</span>`;
    const meta = document.querySelectorAll(".estimate-meta span");
    if (meta.length >= 2) {
      meta[0].textContent = `${curSize.toLocaleString("en-AE")} ${unitWord} × AED ${validPrice.toFixed(2)}`;
      const totalAll = Math.round(estTotal * curMonths);
      meta[1].innerHTML = `${curMonths}-month total: <span class="total">AED ${totalAll.toLocaleString("en-AE")}</span>`;
    }
    const periodStr = `${curMonths} Month${curMonths === 1 ? "" : "s"}`;
    const eb = document.querySelector(".btn-estimate");
    if (eb) {
      const qs = new URLSearchParams({ id: w.id, size: curSize, unit: sizeUnit, period: periodStr, goodsIntent }).toString();
      eb.href = `estimate.html?${qs}`;
    }
  }
  recompute();

  const setMonths = (m) => {
    curMonths = Math.max(1, Math.min(36, m));
    document.getElementById("d-dur-val").textContent = curMonths;
    document.getElementById("d-dur-unit").textContent = curMonths === 1 ? "Month" : "Months";
    recompute();
  };
  const setSize = (s) => {
    curSize = Math.max(sizeLim.min, Math.min(sizeLim.max, s));
    document.getElementById("d-sz-val").textContent = curSize.toLocaleString("en-AE");
    recompute();
  };
  document.getElementById("d-dur-minus").onclick = () => setMonths(curMonths - 1);
  document.getElementById("d-dur-plus").onclick = () => setMonths(curMonths + 1);
  document.getElementById("d-sz-minus").onclick = () => setSize(curSize - sizeStep);
  document.getElementById("d-sz-plus").onclick = () => setSize(curSize + sizeStep);

  /* Storage options — derive from rateCard zones + instant availability */
  const optionsWrap = document.querySelector(".storage-options");
  if (optionsWrap) {
    const label = optionsWrap.querySelector(".storage-options-label");
    optionsWrap.querySelectorAll(".storage-option").forEach(n => n.remove());
    const zones = getTempZones(w);
    const opts = [];
    if (zones.length) {
      const zoneRow = w.rateCard.find(r => r.uom === sizeUnit) || w.rateCard[0];
      opts.push({ name: zones[0], price: zoneRow ? zoneRow.price : validPrice, sub: zoneRow ? zoneRow.cargo : "Standard cargo", chip: null });
    }
    if (w.instantAvailability && w.instantAvailability.fixedArea > 0) {
      opts.push({ name: "Fixed Area", price: validPrice, sub: "Self managed, no handling fee", chip: "24hr move-in" });
    }
    if (w.lockableUnits && w.lockableUnits.length > 0) {
      const u = w.lockableUnits[0];
      opts.push({ name: "Lockable Unit", price: (u.price / u.size).toFixed(2) * 1, sub: `${w.lockableUnits.length} sizes from ${w.lockableUnits[0].size} ${unitWord}`, chip: "24hr move-in" });
    }
    opts.forEach((o, i) => {
      const div = document.createElement("div");
      div.className = "storage-option" + (i === 0 ? " selected" : "");
      const chipHTML = o.chip
        ? `<span class="option-chip"><svg viewBox="0 0 24 24"><polygon points="13,2 3,14 12,14 11,22 21,10 12,10"/></svg>${o.chip}</span>` : "";
      div.innerHTML = `<div class="radio"></div>
        <div class="option-body">
          <div class="option-row">
            <span class="option-name">${o.name}${chipHTML}</span>
            <span class="option-price">${Number(o.price).toFixed(2)}/${unitWord}</span>
          </div>
          <span class="option-sub">${o.sub}</span>
        </div>`;
      optionsWrap.appendChild(div);
    });
    optionsWrap.querySelectorAll(".storage-option").forEach(opt => {
      opt.onclick = () => {
        optionsWrap.querySelectorAll(".storage-option").forEach(o => o.classList.remove("selected"));
        opt.classList.add("selected");
      };
    });
  }

  /* "Get Free Estimate" CTA → estimate.html with current state */
  const estBtn = document.querySelector(".btn-estimate");
  if (estBtn) {
    const qs = new URLSearchParams({ id: w.id, size: sizeInput, unit: sizeUnit, period: period, goodsIntent: goodsIntent }).toString();
    estBtn.href = `estimate.html?${qs}`;
  }

  /* ----- Nearby — same emirate, exclude current, top 3 ----- */
  const nearby = WAREHOUSES.filter(x => x.emirate === w.emirate && x.id !== w.id).slice(0, 3);
  const miniCards = document.querySelectorAll(".nearby-grid .mini-card");
  miniCards.forEach((card, i) => {
    const nw = nearby[i];
    if (!nw) { card.style.display = "none"; return; }
    card.style.display = "";
    const img = card.querySelector(".mini-card-image img");
    if (img && nw.images && nw.images[0]) { img.src = nw.images[0].url; img.alt = nw.id; }
    const badge = card.querySelector(".mini-card-badge");
    const isInstant = !!(nw.instantAvailability && nw.instantAvailability.fixedArea > 0);
    if (badge) {
      badge.classList.toggle("instant", isInstant);
      badge.classList.toggle("standard", !isInstant);
      const txt = isInstant ? "24hr move-in" : "3-5 day move-in";
      const svg = isInstant
        ? '<svg viewBox="0 0 24 24"><polygon points="13,2 3,14 12,14 11,22 21,10 12,10"/></svg>'
        : '<svg viewBox="0 0 24 24"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>';
      badge.innerHTML = svg + txt;
    }
    card.querySelector(".mini-card-name").textContent = nw.id;
    card.querySelector(".mini-card-rating .score").textContent = nw.rating.toFixed(1);
    card.querySelector(".mini-card-rating .reviews").textContent = `(${nw.reviews} reviews)`;
    const loc = card.querySelector(".mini-card-location");
    if (loc) {
      const svgEl = loc.querySelector("svg").outerHTML;
      loc.innerHTML = svgEl + `${nw.area}, ${nw.emirate}`;
    }
    const np = getUOMPrice(nw, ctx);
    const npNum = np !== Infinity ? np : (nw.rateCard[0] ? nw.rateCard[0].price : 0);
    const priceEl = card.querySelector(".mini-card-price");
    if (priceEl) priceEl.innerHTML = `AED ${npNum.toLocaleString("en-AE", {minimumFractionDigits:2, maximumFractionDigits:2})} <span class="unit">/${unitWord} per month</span>`;
    const viewBtn = card.querySelector(".mini-btn-view");
    if (viewBtn) {
      viewBtn.onclick = () => {
        const qs = new URLSearchParams({ id: nw.id, size: sizeInput, unit: sizeUnit, period, goodsIntent }).toString();
        location.href = `detail.html?${qs}`;
      };
    }
  });
})();
</script>

</body>
</html>
